# ==========================================
# ระบบจัดการคำร้อง - Environment Variables (ตัวอย่าง)
# คัดลอกไฟล์นี้ไปเป็น .env แล้วแก้ไขค่าตามต้องการ
# ==========================================

# แอปพลิเคชัน
APP_PORT=3000
APP_ENV=development

# ฐานข้อมูล MSSQL
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=YourPassword123!
DB_DATABASE=IB_FormRequests
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-string
JWT_EXPIRES_IN=1d

# CORS - กำหนด origin ที่อนุญาต (คั่นด้วย , ถ้ามีหลายตัว)
# รองรับ: http://localhost:4200, http://192.168.1.100:4200, https://myapp.example.com
CORS_ORIGIN=http://localhost:4200

# อัปโหลดไฟล์
UPLOAD_DEST=./uploads
UPLOAD_MAX_FILE_SIZE=10485760
